{
  "name": "vuecraft",
  "version": "0.0.1",
  "description": "Vue 3 + Element Plus production-grade component library",
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "main": "./dist/vuecraft.cjs",
  "module": "./dist/vuecraft.mjs",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/vuecraft.mjs",
      "require": "./dist/vuecraft.cjs"
    },
    "./dist/vuecraft.css": "./dist/vuecraft.css",
    "./*": "./*"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "element-plus": "^2.14.1",
    "vue": "^3.5.35"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "element-plus": "^2.14.1",
    "happy-dom": "^20.9.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue": "^3.5.35",
    "vue-tsc": "^3.3.3"
  },
  "keywords": [
    "vue",
    "vue3",
    "element-plus",
    "component-library",
    "ui-library"
  ]
}
